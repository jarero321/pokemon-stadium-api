{
  "name": "pokemon-stadium-api",
  "version": "1.0.0",
  "description": "Pokemon Stadium Lite - Backend API with WebSockets",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "pokemon",
    "websocket",
    "fastify",
    "clean-architecture"
  ],
  "license": "MIT",
  "type": "module",
  "imports": {
    "#core/*": "./src/core/*",
    "#application/*": "./src/application/*",
    "#infrastructure/*": "./src/infrastructure/*",
    "#config/*": "./src/config/*"
  },
  "dependencies": {
    "fastify": "^5.8.2",
    "mongoose": "^9.3.0",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}

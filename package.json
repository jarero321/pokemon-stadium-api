{
  "name": "pokemon-stadium-api",
  "version": "1.0.0",
  "description": "Pokemon Stadium Lite - Backend API with WebSockets",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "pokemon",
    "websocket",
    "fastify",
    "clean-architecture"
  ],
  "license": "MIT",
  "type": "module",
  "imports": {
    "#core/*": "./src/core/*",
    "#application/*": "./src/application/*",
    "#infrastructure/*": "./src/infrastructure/*",
    "#config/*": "./src/config/*"
  },
  "dependencies": {
    "fastify": "^5.8.2",
    "mongoose": "^9.3.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
